{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    }
  },
  "ElasticSearch": {
    "Uri": "http://localhost:9200"
  },
  "JwtSettings": {
    "Secret": "SuperSecretKeyEnterpriseTierVector99999YourCompanySecretKey",
    "Issuer": "MyProjectBackend",
    "Audience": "MyProjectFrontend",
    "AccessTokenExpirationMinutes": 15,
    "RefreshTokenExpirationDays": 7
  },
  "Redis": {
    "ConnectionString": "localhost:6379"
  },
  "AllowedHosts": "*"
}
